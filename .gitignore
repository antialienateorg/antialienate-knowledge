# ── Public-repo exclusions (knowledge content only) ───────────────────
# Build env + output (regenerated by publish-knowledge.sh)
.venv/
_site/
docs/
.firebase/
firebase.json
.firebaserc
# Marketing media — not knowledge (served/used elsewhere, too bulky for git)
videos/
infographics/
# Stale Cloudflare-deploy workflow (deploy now runs Archon -> Firebase)
.github/workflows/docs.yml
# Internal ops / drafts — must not be public
ARCHITECTURE.md
dashboard/
press/
digest/
analytics.html
# Internal deploy/analytics tooling (reference private token paths)
bin/aa-push
bin/aa-analytics
# Generated case-law JSON (built by `aa-build caselaw`, served from Firebase)
case-law/**/*.json
case-law/index.json
